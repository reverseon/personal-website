<h2 id="train-of-thoughts">Train of Thoughts</h2>
<% if thoughts.empty? %>
  <p style="color: #8b949e; font-style: italic; margin: 2rem 0;">No thoughts yet.</p>
<% else %>
  <div class="thoughts-timeline">
    <% thoughts.first(3).each do |thought| %>
      <% counter = { count: 0 } %>
      <%= render_partial('thoughts/_content', { thought: thought, depth: 0, max_depth: 2, counter: counter, max_items: 3 }) %>
    <% end %>
  </div>
  <% if thoughts.length > 3 %>
    <div class="see-more-container">
      <a href="/carriages/1.html" class="see-more-link pill-link">See All Thoughts <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
    </div>
  <% end %>
<% end %>
