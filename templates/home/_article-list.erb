<h2>My Notes</h2>
<% if @posts.empty? %>
  <p style="color: #8b949e; font-style: italic; margin: 2rem 0;">No posts yet.</p>
<% else %>
  <div class="posts-list">
    <% @posts.sort_by { |post| -post[:published_unix] }.first(3).each do |post| %>
      <%= render_partial('posts/_item', { post: post }) %>
    <% end %>
  </div>
  <% if @posts.length > 3 %>
    <div class="see-more-container">
      <a href="/posts/1.html" class="see-more-link pill-link">See more <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
    </div>
  <% end %>
<% end %>

<h4>Categories</h4>
<% if categories.empty? %>
  <p style="color: #8b949e; font-style: italic;">No categories yet.</p>
<% else %>
  <p class="category-list"><%= categories.map.with_index { |cat, i| i == categories.length - 1 ? "<a href=\"/posts/category/#{cat.downcase}/1.html\">#{cat}</a>." : "<a href=\"/posts/category/#{cat.downcase}/1.html\">#{cat}</a>" }.join(', ') %></p>
<% end %>
<h4>Tags</h4>
<% if tags.empty? %>
  <p style="color: #8b949e; font-style: italic;">No tags yet.</p>
<% else %>
  <p class="tag-list"><%= tags.map.with_index { |tag, i| i == tags.length - 1 ? "<a href=\"/posts/tag/#{tag.downcase}/1.html\">##{tag}</a>." : "<a href=\"/posts/tag/#{tag.downcase}/1.html\">##{tag}</a>" }.join(', ') %></p>
<% end %>